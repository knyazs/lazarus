				"cell_type": "code",
				"source": [
					"from lxml import html\n",
					"import requests\n",
					"from bs4 import BeautifulSoup\n",
					"\n",
					"r = requests.get('https://www.nepremicnine.net/oglasi-prodaja/ljubljana-mesto/stanovanje/').text.encode('utf8').decode('ascii', 'ignore')\n",
					"#tree = html.fromstring(page.text)\n",
					"\n",
					"soup = BeautifulSoup(r, 'lxml')\n",
					"li = soup.find_all('div', {'itemprop': 'itemListElement'})\n",
					"\n",
					"for l in li:\n",
					"\n",
					"    title = l.find('div', {'class': 'kratek'}).text\n",
					"    print(title)\n",
					"\n",
					"\n",
					"next_url = soup.find('a', {'class': 'next'})"
				],
				"execution_count": null
			}
		]
	}
